{
    "name": "bella-baxter/symfony",
    "description": "Symfony Bundle for the Bella Baxter secret management platform",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "secrets",
        "vault",
        "bella-baxter",
        "symfony",
        "bundle",
        "secret-management"
    ],
    "homepage": "https://bella-baxter.io",
    "support": {
        "source": "https://github.com/cosmic-chimps/bella-baxter-php",
        "issues": "https://github.com/cosmic-chimps/bella-baxter-php/issues",
        "docs": "https://docs.bella-baxter.io"
    },
    "require": {
        "php": "^8.1",
        "bella-baxter/sdk": "0.1.1-beta.47",
        "symfony/http-kernel": "^6.0 || ^7.0",
        "symfony/dependency-injection": "^6.0 || ^7.0",
        "symfony/config": "^6.0 || ^7.0"
    },
    "require-dev": {
        "symfony/framework-bundle": "^6.0 || ^7.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "BellaBaxter\\Symfony\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BellaBaxter\\Symfony\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
